generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id
  displayName   String
  loginProvider String
  premiumStatus String
  createdAt     DateTime @default(now())
}

model PetInstance {
  id           String   @id
  ownerId      String
  templateId   String
  level        Int
  experience   Int
  careState    Json
  loadout      Json
  createdAt    DateTime @default(now())
}
